APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# MIGRATIONS_ENABLED=true
# Impostare a false dopo un restore da backup per inibire php artisan migrate (default: true)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Ingestion workflow: base path for extraction, tmp, run storage (unzip, work dir, images lookup)
#INGEST_FS_ROOT=/var/lib/iartnet/ingestion
INGEST_FS_ROOT="C:/Development/DevIartnet/dataing"

# Import immagini Mirror -> Master: folder di appoggio da cui il server IIIF legge le immagini
IMAGES_ROOT=

# libvips (modalità vips in Synchronize Images)
# Su Windows: usare Git Bash (non il launcher WSL in system32). VIPS_BIN se vips non è nel PATH.
#VIPS_BIN=C:/Tools/vips/bin
#BASH_PATH=C:/Program Files/Git/bin/bash.exe
#IIIF_VIPS_SCRIPT=
IIIF_VIPS_TIMEOUT=600
IIIF_VIPS_JOB_TIMEOUT=3600
PYRAMID_MODE=auto
TILE_SIZE=512
JPEG_Q=90

# IIIF Image API 2.x: base URL pubblico (senza parametri). Usato per url e iiif_image_api_url in web_resources
IIIF_PUBLIC_BASE=
# Timeout (secondi) per eventuali richieste al server IIIF
IIIF_TIMEOUT=60

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# IIF
IMAGES_ROOT="D:/IartImg"
IIIF_PUBLIC_BASE=localhost:8182/iiif/2
#IIIF_PUBLIC_BASE=http://94.23.181.145/iiif/2
IIIF_PORT=8182
IIIF_TIMEOUT=60

#Libre translate
LIBRE_TRANSLATE_URL = http://localhost:8183/translate

# Frontend (Nuxt)
# NUXT_PUBLIC_API_URL=http://localhost:8000/api